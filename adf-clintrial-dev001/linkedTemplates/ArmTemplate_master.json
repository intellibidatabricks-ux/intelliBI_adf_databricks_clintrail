{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adf-clintrial-dev001"
		},
		"ls_adls_clintrail_dev_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'ls_adls_clintrail_dev'"
		},
		"ls_adls_clintrail_dev_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://stclintraildev001.dfs.core.windows.net/"
		},
		"ls_azure_databricks_properties_typeProperties_existingClusterId": {
			"type": "string",
			"defaultValue": "0709-084254-b6vs5dp7"
		},
		"ls_azure_key_vault_secrets_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://kv-azure-keyvault-secret.vault.azure.net/"
		},
		"ls_sqlserver_param_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "@{linkedService().pLsServerName}"
		},
		"ls_sqlserver_param_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "@{linkedService().pLsDatabasename}"
		},
		"ls_sqlserver_param_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "adf_login"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adf-clintrial-dev001_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"ls_adls_clintrail_dev_accountKey": {
						"value": "[parameters('ls_adls_clintrail_dev_accountKey')]"
					},
					"ls_adls_clintrail_dev_properties_typeProperties_url": {
						"value": "[parameters('ls_adls_clintrail_dev_properties_typeProperties_url')]"
					},
					"ls_azure_key_vault_secrets_properties_typeProperties_baseUrl": {
						"value": "[parameters('ls_azure_key_vault_secrets_properties_typeProperties_baseUrl')]"
					},
					"ls_azure_databricks_properties_typeProperties_existingClusterId": {
						"value": "[parameters('ls_azure_databricks_properties_typeProperties_existingClusterId')]"
					},
					"ls_sqlserver_param_properties_typeProperties_server": {
						"value": "[parameters('ls_sqlserver_param_properties_typeProperties_server')]"
					},
					"ls_sqlserver_param_properties_typeProperties_database": {
						"value": "[parameters('ls_sqlserver_param_properties_typeProperties_database')]"
					},
					"ls_sqlserver_param_properties_typeProperties_userName": {
						"value": "[parameters('ls_sqlserver_param_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}