							"isSequential": true,
							"activities": [
								{
									"name": "Notebook_landing_bronze",
									"type": "DatabricksNotebook",
									"dependsOn": [],
									"policy": {
										"timeout": "0.12:00:00",
										"retry": 3,
										"retryIntervalInSeconds": 30,
										"secureOutput": false,
										"secureInput": false
									},
									"userProperties": [],
									"typeProperties": {
										"notebookPath": "/Users/intellibidatabricks01@gmail.com/intelliBI_databricks_clintrail/landing_bronze_load/03_nb_landing_bronze_load",
										"baseParameters": {
											"domain": {
												"value": "@item().Domain",
												"type": "Expression"
											},
											"storageAccName": {
												"value": "@item().StorageAccName",
												"type": "Expression"
											},
											"srcContainerName": {
												"value": "@item().SrcContainerName",
												"type": "Expression"
											},
											"tgtCatalog": {
												"value": "@item().TgtCatalog",
												"type": "Expression"
											},
											"tgtSchema": {
												"value": "@item().TgtSchema",
												"type": "Expression"
											},
											"tgtTableName": {
												"value": "@item().TgtTableName",
												"type": "Expression"
											}
										}
									},
									"linkedServiceName": {
										"referenceName": "ls_azure_databricks",
										"type": "LinkedServiceReference"
									}
								}
							]
						}
					}
				],
