			"name": "[concat(parameters('factoryName'), '/pl_landing_bronze_data_load')]",
			"type": "Microsoft.DataFactory/factories/pipelines",
			"apiVersion": "2018-06-01",
			"properties": {
				"activities": [
					{
						"name": "Lookup_Bronze_Control_Table",
						"type": "Lookup",
						"dependsOn": [],
						"policy": {
							"timeout": "0.12:00:00",
							"retry": 3,
							"retryIntervalInSeconds": 30,
							"secureOutput": false,
							"secureInput": false
						},
						"userProperties": [],
						"typeProperties": {
							"source": {
								"type": "SqlServerSource",
								"queryTimeout": "02:00:00",
								"partitionOption": "None"
							},
							"dataset": {
								"referenceName": "ds_sqlserver_source_tables_param",
								"type": "DatasetReference",
								"parameters": {
									"pDsServerName": "localhost\\SQLEXPRESS",
									"pDsDatabasename": "dev_clintrail_edc_src",
									"pDsSchemaName": "edcsrcmetadata",
									"pDsTableName": "srcEdcLandToBronzeControl"
								}
							},
							"firstRowOnly": false
						}
					},
					{
						"name": "ForEach_Landing_File",
						"type": "ForEach",
						"dependsOn": [
							{
								"activity": "Lookup_Bronze_Control_Table",
								"dependencyConditions": [
									"Succeeded"
								]
							}
						],
						"userProperties": [],
						"typeProperties": {
							"items": {
								"value": "@activity('Lookup_Bronze_Control_Table').output.value",
								"type": "Expression"
