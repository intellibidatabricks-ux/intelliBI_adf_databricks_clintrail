		{
			"name": "[concat(parameters('factoryName'), '/pl_sqlserver_src_adls_landing')]",
			"type": "Microsoft.DataFactory/factories/pipelines",
			"apiVersion": "2018-06-01",
			"properties": {
				"activities": [
					{
						"name": "LookupSQLServerControlTable",
						"type": "Lookup",
						"dependsOn": [],
						"policy": {
							"timeout": "0.12:00:00",
							"retry": 3,
							"retryIntervalInSeconds": 30,
							"secureOutput": false,
							"secureInput": false
						},
						"userProperties": [],
						"typeProperties": {
							"source": {
								"type": "SqlServerSource",
								"sqlReaderQuery": {
									"value": "@concat('SELECT * FROM [', pipeline().parameters.pSchemaName,\n        '].[', pipeline().parameters.pTableName,\n        '] WHERE Enabled = ''True''')",
									"type": "Expression"
								},
								"queryTimeout": "02:00:00",
								"partitionOption": "None"
							},
							"dataset": {
								"referenceName": "ds_sqlserver_source_tables_param",
								"type": "DatasetReference",
								"parameters": {
									"pDsServerName": {
										"value": "@pipeline().parameters.pServerName",
										"type": "Expression"
									},
									"pDsDatabasename": {
										"value": "@pipeline().parameters.pDatabasename",
										"type": "Expression"
									},
									"pDsSchemaName": {
										"value": "@pipeline().parameters.pSchemaName",
										"type": "Expression"
									},
									"pDsTableName": {
										"value": "@pipeline().parameters.pTableName",
										"type": "Expression"
									}
								}
							},
							"firstRowOnly": false
						}
					},
					{
						"name": "ForEach1",
						"type": "ForEach",
						"dependsOn": [
							{
								"activity": "LookupSQLServerControlTable",
								"dependencyConditions": [
									"Succeeded"
								]
							}
						],
						"userProperties": [],
						"typeProperties": {
							"items": {
								"value": "@activity('LookupSQLServerControlTable').output.value",
								"type": "Expression"
							},
							"isSequential": true,
							"activities": [
								{
									"name": "Copydata_sqlserver_landing",
									"type": "Copy",
									"dependsOn": [],
									"policy": {
										"timeout": "0.12:00:00",
										"retry": 3,
										"retryIntervalInSeconds": 30,
										"secureOutput": false,
										"secureInput": false
									},
									"userProperties": [
										{
											"name": "Source",
											"value": "@{item().SrcSchemaName}.@{item().SrcTableName}"
										},
										{
											"name": "Destination",
											"value": "@{item().LandingContainerName}/@{concat(item().SrcSchemaName,'/',item().SrcTableName,'/ingest_date=',formatDateTime(utcNow(),'yyyy-MM-dd'))}/@{concat(item().SrcTableName, '_', formatDateTime(utcNow(),'yyyyMMddHHmmss'), '.parquet')}"
										}
									],
									"typeProperties": {
										"source": {
											"type": "SqlServerSource",
											"sqlReaderQuery": {
												"value": "@if(equals(item().IngestionType,'Incremental'),\n    concat('SELECT * FROM ',item().SrcSchemaName,'.',item().SrcTableName,\n           ' WHERE ',coalesce(item().WatermarkColName,''),\n           ' > ''',coalesce(string(item().WatermarkColValue),''),''''),\n    concat('SELECT * FROM ',item().SrcSchemaName,'.',item().SrcTableName))",
												"type": "Expression"
											},
											"queryTimeout": "02:00:00",
											"partitionOption": "None"
										},
										"sink": {
											"type": "ParquetSink",
											"storeSettings": {
												"type": "AzureBlobFSWriteSettings"
											},
											"formatSettings": {
												"type": "ParquetWriteSettings"
											}
										},
										"enableStaging": false,
										"translator": {
											"type": "TabularTranslator",
											"typeConversion": true,
											"typeConversionSettings": {
												"allowDataTruncation": true,
												"treatBooleanAsNumber": false
											}
										}
									},
									"inputs": [
										{
											"referenceName": "ds_sqlserver_source_tables_param",
											"type": "DatasetReference",
											"parameters": {
												"pDsServerName": {
													"value": "@item().SrcServerName",
													"type": "Expression"
												},
												"pDsDatabasename": {
													"value": "@item().SrcDatabaseName",
													"type": "Expression"
												},
												"pDsSchemaName": {
													"value": "@item().SrcSchemaName",
													"type": "Expression"
												},
												"pDsTableName": {
													"value": "@item().SrcTableName",
													"type": "Expression"
												}
											}
										}
									],
									"outputs": [
										{
											"referenceName": "ds_adls_landing_parquet_param",
											"type": "DatasetReference",
											"parameters": {
												"pDsFileName": {
													"value": "@{concat(item().SrcTableName, '_', formatDateTime(utcNow(),'yyyyMMddHHmmss'), '.parquet')}",
													"type": "Expression"
												},
												"pDsFolderName": "@{concat(item().SrcSchemaName,'/',item().SrcTableName,'/ingest_date=',formatDateTime(utcNow(),'yyyy-MM-dd'))}",
												"pDsContainerName": {
													"value": "@item().LandingContainerName",
													"type": "Expression"
												}
											}
										}
									]
								},
								{
									"name": "LookupGetMaxMetaData",
									"type": "Lookup",
									"dependsOn": [
										{
											"activity": "Copydata_sqlserver_landing",
											"dependencyConditions": [
												"Succeeded"
											]
										}
									],
									"policy": {
										"timeout": "0.12:00:00",
										"retry": 3,
										"retryIntervalInSeconds": 30,
										"secureOutput": false,
										"secureInput": false
									},
									"userProperties": [],
									"typeProperties": {
										"source": {
											"type": "SqlServerSource",
											"sqlReaderQuery": {
												"value": "@concat('SELECT MAX([', coalesce(item().WatermarkColName,'MODIFIED_TS'),\n        ']) AS NewWatermark FROM ', item().SrcSchemaName, '.', item().SrcTableName)",
												"type": "Expression"
											},
											"queryTimeout": "02:00:00",
											"partitionOption": "None"
										},
										"dataset": {
											"referenceName": "ds_sqlserver_source_tables_param",
											"type": "DatasetReference",
											"parameters": {
												"pDsServerName": "localhost\\SQLEXPRESS",
												"pDsDatabasename": "dev_clintrail_edc_src",
												"pDsSchemaName": "edcsrcmetadata",
												"pDsTableName": "srcEdcClintrailToLandControl"
											}
										}
									}
								},
								{
									"name": "Stored procedureUpdtMxModifiedDt",
									"type": "SqlServerStoredProcedure",
									"dependsOn": [
										{
											"activity": "LookupGetMaxMetaData",
											"dependencyConditions": [
												"Succeeded"
											]
										}
									],
									"policy": {
										"timeout": "0.12:00:00",
										"retry": 3,
										"retryIntervalInSeconds": 30,
										"secureOutput": false,
										"secureInput": false
									},
									"userProperties": [],
									"typeProperties": {
										"storedProcedureName": "[[edcsrcmetadata].[usp_UpdateMxWatermark]",
										"storedProcedureParameters": {
											"MetadataId": {
												"value": {
													"value": "@item().MetadataId",
													"type": "Expression"
												},
												"type": "Int32"
											},
											"NewWatermarkValue": {
												"value": {
													"value": "@activity('LookupGetMaxMetaData').output.firstRow.NewWatermark",
													"type": "Expression"
												},
												"type": "DateTime"
											}
										}
									},
									"linkedServiceName": {
										"referenceName": "ls_sqlserver_param",
										"type": "LinkedServiceReference",
										"parameters": {
											"pLsServerName": {
												"value": "@item().SrcServerName",
												"type": "Expression"
											},
											"pLsDatabasename": {
												"value": "@item().SrcDatabaseName",
												"type": "Expression"
											}
										}
									}
								}
							]
						}
					}
				],
				"policy": {
					"elapsedTimeMetric": {}
				},
				"parameters": {
					"pServerName": {
						"type": "string",
						"defaultValue": "localhost\\SQLEXPRESS"
					},
					"pDatabasename": {
						"type": "string",
						"defaultValue": "dev_clintrail_edc_src"
					},
					"pSchemaName": {
						"type": "string",
						"defaultValue": "edcsrcmetadata"
					},
					"pTableName": {
						"type": "string",
						"defaultValue": "srcEdcClintrailToLandControl"
					}
				},
				"folder": {
					"name": "dev_clintrail/source_landing_load"
				},
				"annotations": []
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/datasets/ds_sqlserver_source_tables_param')]",
				"[concat(variables('factoryId'), '/datasets/ds_adls_landing_parquet_param')]",
